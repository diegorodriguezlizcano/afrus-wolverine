# afrus-Wolverine — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to source control.

# =============================================================================
# APPLICATION
# =============================================================================
NODE_ENV=development
PORT=3000
LOG_LEVEL=info

# =============================================================================
# DATABASE (PostgreSQL)
# Individual components used by AppConfigService to build DATABASE_URL.
# Prisma also reads DATABASE_URL directly.
# =============================================================================
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_NAME=wolverine
DATABASE_USER=wolverine
DATABASE_PASSWORD=change_me_in_production
DATABASE_SSL=false
# DATABASE_URL is used by PrismaClient directly; you can also let
# AppConfigService.getDatabaseUrl() build it from the individual vars above.
DATABASE_URL="postgresql://wolverine:change_me_in_production@localhost:5432/wolverine?sslmode=disable"

# =============================================================================
# JWT AUTHENTICATION (for REST API)
# =============================================================================
JWT_SECRET=change_me_use_strong_random_string_in_production_at_least_20_chars
JWT_EXPIRES_IN=7d

# =============================================================================
# LLM PROVIDERS
# Set LLM_PROVIDER to either 'openrouter' or 'deepinfra'.
# Provide the corresponding API key.
# =============================================================================
LLM_PROVIDER=openrouter

# OpenRouter (https://openrouter.ai)
OPENROUTER_API_KEY=

# DeepInfra (https://deepinfra.com)
DEEPINFRA_API_KEY=

# =============================================================================
# AFRUS
# AFRUS_API_KEY is the default org key used during initial setup / onboarding.
# In production, each Organization stores its own afrus_api_key in the DB.
# AFRUS_API_URL defaults to https://backend.afrus.app.
# =============================================================================
AFRUS_API_URL=https://backend.afrus.app
AFRUS_API_KEY=

# =============================================================================
# ALMA — DEPRECATED
# afrus handles ALMA communication directly.
# Set ALMA_ENABLED=true only when ALMA integration is explicitly needed.
# =============================================================================
ALMA_ENABLED=false
ALMA_WEBHOOK_URL=https://backend.afrus.app/api/v1/alma/webhook
ALMA_WEBHOOK_SECRET=
