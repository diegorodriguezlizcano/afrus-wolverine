# afrus-Wolverine — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to source control.

# =============================================================================
# APPLICATION
# =============================================================================
NODE_ENV=development
PORT=3000

# =============================================================================
# DATABASE (PostgreSQL)
# =============================================================================
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_NAME=wolverine
DATABASE_USER=wolverine
DATABASE_PASSWORD=change_me_in_production

# =============================================================================
# LLM PROVIDERS
# =============================================================================
# Which LLM provider to use: openrouter | deepinfra
LLM_PROVIDER=openrouter

# OpenRouter (https://openrouter.ai)
OPENROUTER_API_KEY=

# DeepInfra (https://deepinfra.com)
DEEPINFRA_API_KEY=

# =============================================================================
# AFRUS (Global — overridden per-org in database)
# =============================================================================
# Default afrus API key for initial setup / onboarding.
# In production, each Organization stores its own afrus_api_key in the database.
AFRUS_API_KEY=
AFRUS_API_URL=https://backend.afrus.app

# =============================================================================
# ALMA (afrus AI Agent)
# =============================================================================
ALMA_WEBHOOK_URL=https://backend.afrus.app/alma/webhook
ALMA_WEBHOOK_SECRET=

# =============================================================================
# JWT AUTHENTICATION (for REST API)
# =============================================================================
JWT_SECRET=change_me_use_strong_random_string_in_production
JWT_EXPIRES_IN=7d

# =============================================================================
# LOGGING
# =============================================================================
LOG_LEVEL=info

# =============================================================================
# NOTES
# =============================================================================
# - All secrets should be loaded from .env at runtime.
# - Per-organization afrus_api_key is stored in the database (organizations table).
#   Individual org keys are NOT stored in environment variables.
# - For local development: docker-compose up
# - For production: build and deploy the Docker image with a proper secrets manager.
